# Copy this file to .env and fill in real values locally. Never commit the real .env file.
# Used by notebooks/01_data_preparation.ipynb (Section 2) to authenticate against a specific
# MT5 trading account for reproducible data extraction. If left unset, the notebook falls back
# to whatever MT5 terminal session is already logged in on the machine, or to the historical
# results/eurusd_features.csv snapshot when no MT5 terminal is reachable at all.

MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Used by src/macro_data.py to fetch the US 10Y / German 10Y bond yield
# differential via the official FRED API (fredapi). Optional: if left unset,
# the pipeline transparently falls back to FRED's public CSV endpoint via
# pandas_datareader (no key required), then to the last cached snapshot in
# results/yield_differential.csv if neither live source is reachable.
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY_HERE
